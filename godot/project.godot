; Engine configuration file
; Godot 4.x — LoveLetter cross-platform rewrite

config_version=5

[application]

config/name="LoveLetter"
config/description="A 2D physics puzzle game — cross-platform rewrite"
config/version="2.0.0"
run/main_scene="res://scenes/boot/Boot.tscn"
config/features=PackedStringArray("4.3")

[autoload]

GameState="*res://scripts/app/game_state.gd"
LevelProgress="*res://scripts/app/level_progress.gd"
EventBus="*res://scripts/app/event_bus.gd"
AudioManager="*res://scripts/app/audio_manager.gd"
SceneRouter="*res://scripts/app/scene_router.gd"

[display]

window/size/viewport_width=800
window/size/viewport_height=480
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input]

